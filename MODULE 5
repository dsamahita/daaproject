👉 This gives you extra edge if prof pushes you

Code (simplified version)
#include <bits/stdc++.h>
using namespace std;

struct Point {
    int x, y;
};

double dist(Point a, Point b) {
    return sqrt((a.x - b.x)*(a.x - b.x) +
                (a.y - b.y)*(a.y - b.y));
}

// Brute force (base case)
double brute(vector<Point>& pts, int l, int r) {
    double mn = DBL_MAX;
    for (int i = l; i <= r; i++)
        for (int j = i+1; j <= r; j++)
            mn = min(mn, dist(pts[i], pts[j]));
    return mn;
}

double closestUtil(vector<Point>& pts, int l, int r) {
    if (r - l <= 3)
        return brute(pts, l, r);

    int mid = (l + r) / 2;

    double dl = closestUtil(pts, l, mid);
    double dr = closestUtil(pts, mid+1, r);

    return min(dl, dr);
}

double closestPair(vector<Point>& pts) {
    sort(pts.begin(), pts.end(), [](Point a, Point b) {
        return a.x < b.x;
    });

    return closestUtil(pts, 0, pts.size()-1);
}

int main() {
    vector<Point> warehouses = {
        {2, 3}, {12, 30}, {40, 50},
        {5, 1}, {12, 10}, {3, 4}
    };

    cout << "Closest Distance: "
         << closestPair(warehouses);

    return 0;
}
