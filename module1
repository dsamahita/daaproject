MODULE 1: DELIVERY PRIORITIZATION ENGINE
Objective

To efficiently sort and prioritize delivery requests based on multiple parameters like:

Deadline
Customer priority
Distance
Weight

So that:

Urgent deliveries are handled first
High-value customers are prioritized
Overall system efficiency improves
#include <bits/stdc++.h>
using namespace std;

struct Delivery {
    int id;
    int deadline;
    int priority;
};

// ---------------- MERGE SORT (by deadline) ----------------

void merge(vector<Delivery>& arr, int l, int m, int r) {
    vector<Delivery> L(arr.begin()+l, arr.begin()+m+1);
    vector<Delivery> R(arr.begin()+m+1, arr.begin()+r+1);

    int i = 0, j = 0, k = l;

    while (i < L.size() && j < R.size()) {
        if (L[i].deadline <= R[j].deadline)
            arr[k++] = L[i++];
        else
            arr[k++] = R[j++];
    }

    while (i < L.size()) arr[k++] = L[i++];
    while (j < R.size()) arr[k++] = R[j++];
}

void mergeSort(vector<Delivery>& arr, int l, int r) {
    if (l >= r) return;

    int m = (l + r) / 2;

    mergeSort(arr, l, m);
    mergeSort(arr, m + 1, r);

    merge(arr, l, m, r);
}

// ---------------- QUICK SORT (by priority) ----------------

int partition(vector<Delivery>& arr, int low, int high) {
    int pivot = arr[high].priority;
    int i = low - 1;

    for (int j = low; j < high; j++) {
        if (arr[j].priority > pivot) {
            i++;
            swap(arr[i], arr[j]);
        }
    }

    swap(arr[i + 1], arr[high]);
    return i + 1;
}

void quickSort(vector<Delivery>& arr, int low, int high) {
    if (low < high) {
        int pi = partition(arr, low, high);

        quickSort(arr, low, pi - 1);
        quickSort(arr, pi + 1, high);
    }
}

// ---------------- MAIN ----------------

int main() {
    vector<Delivery> deliveries = {
        {1, 5, 2},
        {2, 2, 5},
        {3, 3, 1},
        {4, 1, 4}
    };

    // Sort by deadline
    mergeSort(deliveries, 0, deliveries.size() - 1);

    cout << "Sorted by Deadline:\n";
    for (auto d : deliveries)
        cout << "ID: " << d.id << " Deadline: " << d.deadline << endl;

    // Sort by priority
    quickSort(deliveries, 0, deliveries.size() - 1);

    cout << "\nSorted by Priority:\n";
    for (auto d : deliveries)
        cout << "ID: " << d.id << " Priority: " << d.priority << endl;

    return 0;
}

