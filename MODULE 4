MODULE 4: DYNAMIC PROGRAMMING (OPTIMAL COST MINIMIZATION)
Objective

To compute globally optimal solutions where greedy fails, such as:

Maximizing delivery value under strict constraints
Minimizing total delivery cost across multiple stops
Precomputing shortest paths between all locations

“Greedy makes local decisions, but logistics often requires global optimization. Dynamic Programming ensures optimal solutions by solving overlapping subproblems and storing results.”

#include <bits/stdc++.h>
using namespace std;

int knapsack(int W, vector<int>& wt, vector<int>& val, int n) {
    // DP table
    vector<vector<int>> dp(n+1, vector<int>(W+1, 0));

    // Fill table
    for (int i = 1; i <= n; i++) {
        for (int w = 0; w <= W; w++) {

            if (wt[i-1] <= w) {
                dp[i][w] = max(
                    dp[i-1][w], 
                    val[i-1] + dp[i-1][w - wt[i-1]]
                );
            } else {
                dp[i][w] = dp[i-1][w];
            }
        }
    }

    return dp[n][W];
}

int main() {
    vector<int> wt = {10, 20, 30};
    vector<int> val = {60, 100, 120};
    int W = 50;

    cout << "Maximum Value: " 
         << knapsack(W, wt, val, wt.size());

    return 0;
}
